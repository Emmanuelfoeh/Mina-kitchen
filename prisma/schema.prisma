// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant Model (White-Label/Franchise)
model Tenant {
  id           String  @id @default(cuid())
  name         String // Restaurant name
  subdomain    String  @unique // e.g., "jollofhub"
  customDomain String? @unique // Optional custom domain

  // Branding
  logo           String?
  primaryColor   String  @default("#FF6B35")
  secondaryColor String  @default("#004E89")
  accentColor    String  @default("#F7931E")

  // Business Info
  businessEmail String
  businessPhone String
  description   String?

  // Features & Billing
  plan         TenantPlan   @default(STARTER)
  status       TenantStatus @default(TRIAL)
  trialEndsAt  DateTime?
  billingCycle BillingCycle @default(MONTHLY)

  // Settings
  settings String // JSON object for tenant-specific settings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users          User[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  packages       Package[]
  orders         Order[]
  carts          Cart[]

  @@map("tenants")
}

// User and Authentication Models
model User {
  id           String   @id @default(cuid())
  email        String
  name         String
  phone        String?
  passwordHash String
  role         UserRole @default(CUSTOMER)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  addresses Address[]
  orders    Order[]
  cart      Cart?

  @@unique([tenantId, email]) // Email unique per tenant
  @@map("users")
}

model Address {
  id         String   @id @default(cuid())
  street     String
  unit       String?
  city       String
  province   String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Used for delivery addresses in orders
  deliveryOrders Order[]

  @@map("addresses")
}

// Menu and Product Models
model MenuCategory {
  id           String  @id @default(cuid())
  name         String
  description  String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  menuItems MenuItem[]

  @@unique([tenantId, name]) // Category name unique per tenant
  @@map("menu_categories")
}

model MenuItem {
  id              String     @id @default(cuid())
  name            String
  description     String
  basePrice       Float
  image           String
  status          ItemStatus @default(ACTIVE)
  tags            String // JSON array stored as string
  chefNotes       String?
  preparationTime Int?
  allergens       String[] // Array of allergen strings
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  categoryId String
  category   MenuCategory @relation(fields: [categoryId], references: [id])

  customizations Customization[]
  orderItems     OrderItem[]
  packageItems   PackageItem[]
  cartItems      CartItem[]

  @@unique([tenantId, categoryId, name]) // Menu item name unique per category per tenant
  @@map("menu_items")
}

model Customization {
  id            String            @id @default(cuid())
  name          String
  type          CustomizationType
  required      Boolean           @default(false)
  maxSelections Int?

  // Relations
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  options CustomizationOption[]

  @@unique([menuItemId, name])
  @@map("customizations")
}

model CustomizationOption {
  id            String  @id @default(cuid())
  name          String
  priceModifier Float   @default(0)
  isAvailable   Boolean @default(true)

  // Relations
  customizationId String
  customization   Customization @relation(fields: [customizationId], references: [id], onDelete: Cascade)

  @@map("customization_options")
}

// Remove the NutritionalInfo model entirely

// Package Models
model Package {
  id             String      @id @default(cuid())
  name           String
  slug           String?
  description    String
  type           PackageType
  price          Float
  image          String?
  isActive       Boolean     @default(true)
  features       String // JSON array stored as string
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  includedItems PackageItem[]

  @@unique([tenantId, slug]) // Slug unique per tenant
  @@map("packages")
}

model PackageItem {
  id                     String @id @default(cuid())
  quantity               Int    @default(1)
  includedCustomizations String // JSON array stored as string

  // Relations
  packageId  String
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("package_items")
}

// Cart Models
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id                     String   @id @default(cuid())
  quantity               Int
  unitPrice              Float
  totalPrice             Float
  selectedCustomizations String // JSON stored as string for SelectedCustomization[]
  specialInstructions    String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("cart_items")
}

// Order Models
model Order {
  id                  String        @id @default(cuid())
  orderNumber         String
  subtotal            Float
  tax                 Float
  deliveryFee         Float
  tip                 Float         @default(0)
  total               Float
  status              OrderStatus   @default(PENDING)
  deliveryType        DeliveryType
  scheduledFor        DateTime?
  estimatedDelivery   DateTime?
  paymentStatus       PaymentStatus @default(PENDING)
  specialInstructions String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  customerId        String
  customer          User     @relation(fields: [customerId], references: [id])
  deliveryAddressId String?
  deliveryAddress   Address? @relation(fields: [deliveryAddressId], references: [id])

  items OrderItem[]

  @@unique([tenantId, orderNumber]) // Order number unique per tenant
  @@map("orders")
}

model OrderItem {
  id                  String  @id @default(cuid())
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  customizations      String // JSON stored as string for SelectedCustomization[]
  specialInstructions String?

  // Relations
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// Enums
enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN // For platform admin managing all tenants
}

enum TenantPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
  LOW_STOCK
}

enum CustomizationType {
  RADIO
  CHECKBOX
  TEXT
}

enum PackageType {
  DAILY
  WEEKLY
  MONTHLY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}
